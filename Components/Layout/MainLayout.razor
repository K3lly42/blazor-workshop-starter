@inherits LayoutComponentBase

@*
    MudBlazor-Provider. Diese liegen im Layout (gerendert innerhalb des
    InteractiveServer-gerenderten <Routes>), damit Theme, Popovers, Dialoge und
    Snackbars alle interaktiv laufen. Wird einmal app-weit benötigt.
*@
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
